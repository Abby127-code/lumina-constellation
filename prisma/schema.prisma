// Lumina Studio V3 - 完整产品 Schema
// 8 大赛道 + 账号体系 + Stripe 订阅 + 多语言

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  passwordHash String?  // 邮箱注册用户
  name         String?
  avatar       String?
  birthDate    String?
  birthTime    String?
  birthPlace   String?
  birthLat     Float?
  birthLng     Float?
  timezone     String?
  gender       String?
  // 订阅
  plan         String   @default("free") // free/pro/premium
  trialEndsAt  DateTime?
  stripeCustomerId    String?
  stripeSubId         String?
  subStatus           String?  // active/trialing/past_due/canceled
  currentPeriodEnd    DateTime?
  // 语言偏好
  locale       String   @default("en") // en/zh/es/pt/ja/hi/ar (English by default)
  // 配额（按日重置）
  dailyUsageCount  Int  @default(0)
  dailyUsageDate   String? // YYYY-MM-DD
  totalReadings    Int     @default(0)
  // 推荐码（用于返佣系统）
  referralCode     String?  @unique
  referredBy       String?  // 推荐人 userId
  // 主题
  theme            String   @default("dark") // dark/light
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  readings     Reading[]
  dreams       Dream[]
  memorials    Memorial[]
  genealogies  Genealogy[]
  dailyReports DailyReport[]
  storybooks   Storybook[]
  prompts      PromptItem[]
  directoryItems DirectoryItem[]
  caregivers   CaregiverLog[]
  microsaas    MicrosaasIdea[]
  images       GeneratedImage[]
  sessions     UserSession[]
  referralsMade   Referral[]      @relation("Referrer")
  referralsReceived Referral[]    @relation("Referred")
  achievements    UserAchievement[]
  notifications   Notification[]
  favorites       Favorite[]
  streaks         UserStreak?
}

// 邮箱登录 session
model UserSession {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique // cookie token
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([token])
  @@index([userId])
}

// 占卜记录
model Reading {
  id          String   @id @default(cuid())
  userId      String
  type        String
  question    String?
  input       String
  result      String
  metadata    String?
  locale      String   @default("en")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, type, createdAt])
}

model Dream {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  mood        String?
  framework   String?
  interpretation String?
  tags        String?
  dreamDate   DateTime
  locale      String   @default("en")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, dreamDate])
}

model Memorial {
  id          String   @id @default(cuid())
  userId      String
  personName  String
  relationship String?
  birthYear   String?
  deathYear   String?
  personality String?
  memories    String?
  photos      String?
  biography   String?
  letterToUser String?
  locale      String   @default("en")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Genealogy {
  id          String   @id @default(cuid())
  userId      String
  familyName  String
  members     String
  origins     String?
  traditions  String?
  narrative   String?
  locale      String   @default("en")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model DailyReport {
  id          String   @id @default(cuid())
  userId      String
  reportDate  DateTime
  energyScore Int
  love        String?
  career      String?
  wealth      String?
  health      String?
  luckyColor  String?
  luckyNumber String?
  summary     String
  locale      String   @default("en")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, reportDate, locale])
  @@index([userId, reportDate])
}

model Storybook {
  id          String   @id @default(cuid())
  userId      String
  childName   String
  childAge    Int
  theme       String
  artStyle    String
  storyTitle  String?
  storyText   String?
  coverPrompt String?
  pages       String?
  moral       String?
  shareUrl    String?
  isFavorite  Boolean  @default(false)
  locale      String   @default("en")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
}

model PromptItem {
  id          String   @id @default(cuid())
  userId      String
  title       String
  category    String
  model       String
  promptText  String
  description String?
  tags        String?
  isPublic    Boolean  @default(false)
  isFavorite  Boolean  @default(false)
  usageCount  Int      @default(0)
  locale      String   @default("en")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, category, createdAt])
  @@index([isPublic, category])
}

model DirectoryItem {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  url         String
  description String
  category    String
  tags        String?
  pricing     String?
  logoUrl     String?
  isFeatured  Boolean  @default(false)
  isApproved  Boolean  @default(true)
  upvotes     Int      @default(0)
  locale      String   @default("en")
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([category, isApproved, createdAt])
  @@index([isFeatured])
}

// 新赛道 5：AI 照护者支持
model CaregiverLog {
  id          String   @id @default(cuid())
  userId      String
  logDate     DateTime
  careType   String   // symptom/medication/mood/incident
  title       String
  content     String
  aiAdvice    String?
  mood        String?  // happy/ok/stressed/exhausted
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, logDate])
}

// 新赛道 8：微 SaaS 创意
model MicrosaasIdea {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  category    String   // chrome-ext/notion-plugin/slack-bot/zapier/shopify-app/stripe-tool
  description String
  targetUser  String
  monetization String? // free/freemium/paid
  mrr         Int      @default(0) // 已验证 MRR（美元/月）
  techStack   String?
  upvotes     Int      @default(0)
  isApproved  Boolean  @default(true)
  locale      String   @default("en")
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([category, isApproved])
}

// AI 生成的图像
model GeneratedImage {
  id          String   @id @default(cuid())
  userId      String
  source      String   // storybook / prompt / standalone
  sourceId    String?  // 关联的 Storybook/Prompt id
  prompt      String
  imageUrl    String?  // base64 或 URL
  style       String?
  width       Int      @default(1024)
  height      Int      @default(1024)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@index([source, sourceId])
}

// 推荐返佣
model Referral {
  id           String   @id @default(cuid())
  referrerId   String   // 推荐人
  referredId   String   // 被推荐人
  code         String   // 推荐码
  status       String   @default("pending") // pending/completed/rewarded
  rewardAmount Float?   // 返佣金额（USD）
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  referrer     User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred     User     @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referredId]) // 一个用户只能被推荐一次
  @@index([referrerId, createdAt])
}

// 用户成就
model UserAchievement {
  id          String   @id @default(cuid())
  userId      String
  type        String   // first_reading / streak_7 / streak_30 / pro_upgrade / 100_readings / shared_content / early_adopter
  title       String
  description String
  icon        String   // emoji
  unlockedAt  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId, unlockedAt])
}

// 用户连续打卡
model UserStreak {
  id           String   @id @default(cuid())
  userId       String   @unique
  currentStreak Int     @default(0)
  maxStreak    Int      @default(0)
  lastActiveDate String? // YYYY-MM-DD
  totalDays    Int      @default(0)
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 站内通知
model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // achievement / referral / streak / system / payment
  title       String
  body        String
  icon        String?   // emoji
  link        String?   // 点击跳转路径
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

// 收藏夹
model Favorite {
  id          String   @id @default(cuid())
  userId      String
  itemType    String   // reading / dream / storybook / prompt / memorial / genealogy / caregiver
  itemId      String
  title       String
  preview     String?  // 内容预览（前 200 字符）
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
  @@index([userId, itemType, createdAt])
}
