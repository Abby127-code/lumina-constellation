// Lumina Studio V3 - 完整产品 Schema
// 8 大赛道 + 账号体系 + Stripe 订阅 + 多语言

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  passwordHash String?  // 邮箱注册用户
  name         String?
  avatar       String?
  birthDate    String?
  birthTime    String?
  birthPlace   String?
  birthLat     Float?
  birthLng     Float?
  timezone     String?
  gender       String?
  // 订阅
  plan         String   @default("free") // free/pro/premium
  trialEndsAt  DateTime?
  stripeCustomerId    String?
  stripeSubId         String?
  subStatus           String?  // active/trialing/past_due/canceled
  currentPeriodEnd    DateTime?
  // 语言偏好
  locale       String   @default("zh") // zh/en/es/pt/ja/hi/ar
  // 配额（按日重置）
  dailyUsageCount  Int  @default(0)
  dailyUsageDate   String? // YYYY-MM-DD
  totalReadings    Int     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  readings     Reading[]
  dreams       Dream[]
  memorials    Memorial[]
  genealogies  Genealogy[]
  dailyReports DailyReport[]
  storybooks   Storybook[]
  prompts      PromptItem[]
  directoryItems DirectoryItem[]
  caregivers   CaregiverLog[]
  microsaas    MicrosaasIdea[]
  images       GeneratedImage[]
  sessions     UserSession[]
}

// 邮箱登录 session
model UserSession {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique // cookie token
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([token])
  @@index([userId])
}

// 占卜记录
model Reading {
  id          String   @id @default(cuid())
  userId      String
  type        String
  question    String?
  input       String
  result      String
  metadata    String?
  locale      String   @default("zh")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, type, createdAt])
}

model Dream {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  mood        String?
  framework   String?
  interpretation String?
  tags        String?
  dreamDate   DateTime
  locale      String   @default("zh")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, dreamDate])
}

model Memorial {
  id          String   @id @default(cuid())
  userId      String
  personName  String
  relationship String?
  birthYear   String?
  deathYear   String?
  personality String?
  memories    String?
  photos      String?
  biography   String?
  letterToUser String?
  locale      String   @default("zh")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Genealogy {
  id          String   @id @default(cuid())
  userId      String
  familyName  String
  members     String
  origins     String?
  traditions  String?
  narrative   String?
  locale      String   @default("zh")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model DailyReport {
  id          String   @id @default(cuid())
  userId      String
  reportDate  DateTime
  energyScore Int
  love        String?
  career      String?
  wealth      String?
  health      String?
  luckyColor  String?
  luckyNumber String?
  summary     String
  locale      String   @default("zh")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, reportDate, locale])
  @@index([userId, reportDate])
}

model Storybook {
  id          String   @id @default(cuid())
  userId      String
  childName   String
  childAge    Int
  theme       String
  artStyle    String
  storyTitle  String?
  storyText   String?
  coverPrompt String?
  pages       String?
  moral       String?
  shareUrl    String?
  isFavorite  Boolean  @default(false)
  locale      String   @default("zh")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
}

model PromptItem {
  id          String   @id @default(cuid())
  userId      String
  title       String
  category    String
  model       String
  promptText  String
  description String?
  tags        String?
  isPublic    Boolean  @default(false)
  isFavorite  Boolean  @default(false)
  usageCount  Int      @default(0)
  locale      String   @default("zh")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, category, createdAt])
  @@index([isPublic, category])
}

model DirectoryItem {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  url         String
  description String
  category    String
  tags        String?
  pricing     String?
  logoUrl     String?
  isFeatured  Boolean  @default(false)
  isApproved  Boolean  @default(true)
  upvotes     Int      @default(0)
  locale      String   @default("zh")
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([category, isApproved, createdAt])
  @@index([isFeatured])
}

// 新赛道 5：AI 照护者支持
model CaregiverLog {
  id          String   @id @default(cuid())
  userId      String
  logDate     DateTime
  careType   String   // symptom/medication/mood/incident
  title       String
  content     String
  aiAdvice    String?
  mood        String?  // happy/ok/stressed/exhausted
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, logDate])
}

// 新赛道 8：微 SaaS 创意
model MicrosaasIdea {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  category    String   // chrome-ext/notion-plugin/slack-bot/zapier/shopify-app/stripe-tool
  description String
  targetUser  String
  monetization String? // free/freemium/paid
  mrr         Int      @default(0) // 已验证 MRR（美元/月）
  techStack   String?
  upvotes     Int      @default(0)
  isApproved  Boolean  @default(true)
  locale      String   @default("zh")
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([category, isApproved])
}

// AI 生成的图像
model GeneratedImage {
  id          String   @id @default(cuid())
  userId      String
  source      String   // storybook / prompt / standalone
  sourceId    String?  // 关联的 Storybook/Prompt id
  prompt      String
  imageUrl    String?  // base64 或 URL
  style       String?
  width       Int      @default(1024)
  height      Int      @default(1024)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@index([source, sourceId])
}
