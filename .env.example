# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Database
DATABASE_URL=file:/tmp/lumina.db

# AI Provider (default: free z-ai-web-dev-sdk)
# For Vercel deployment, set Z_AI_CONFIG environment variable:
# Z_AI_CONFIG={"baseUrl":"https://internal-api.z.ai/v1","apiKey":"Z.ai","chatId":"your-chat-id","token":"your-token","userId":"your-user-id"}

# Optional: DeepSeek (charges money)
# DEEPSEEK_API_KEY=sk-xxx

# Optional: OpenAI (charges money)
# OPENAI_API_KEY=sk-xxx

# Payment: LianLian (mock mode if not set)
# LIANLIAN_API_KEY=xxx
# LIANLIAN_MERCHANT_ID=xxx

# Email (optional)
# RESEND_API_KEY=re_xxx
# MAIL_FROM=Lumina <support@dealcanny.com>

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
